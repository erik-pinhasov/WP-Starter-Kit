#: Module identity
msgid "Security Headers"
msgstr "כותרות אבטחה"

msgid "Add HTTP security headers (CSP, Permissions-Policy, HSTS) and harden WordPress against common attack vectors."
msgstr "הוסף כותרות אבטחת HTTP (CSP, Permissions-Policy, HSTS) וחזק את WordPress מפני וקטורי תקיפה נפוצים."

#: HTTP headers section
msgid "HTTP Security Headers"
msgstr "כותרות אבטחת HTTP"

msgid "X-Content-Type-Options: nosniff"
msgstr "X-Content-Type-Options: nosniff"

msgid "X-Frame-Options: SAMEORIGIN"
msgstr "X-Frame-Options: SAMEORIGIN"

msgid "Referrer-Policy: strict-origin-when-cross-origin"
msgstr "Referrer-Policy: strict-origin-when-cross-origin"

msgid "Permissions-Policy (restrict browser APIs)"
msgstr "Permissions-Policy (הגבל ממשקי דפדפן)"

msgid "Strict-Transport-Security (HSTS) — only enable if your site uses HTTPS exclusively"
msgstr "Strict-Transport-Security (HSTS) — הפעל רק אם האתר שלך משתמש ב-HTTPS בלבד"

msgid "Permissions-Policy Directives"
msgstr "הנחיות Permissions-Policy"

msgid "Comma-separated list of restricted APIs. Default restricts camera, microphone, geolocation, and XR."
msgstr "רשימת ממשקים מוגבלים מופרדת בפסיקים. ברירת המחדל מגבילה מצלמה, מיקרופון, מיקום ו-XR."

msgid "HSTS Max-Age (seconds)"
msgstr "HSTS Max-Age (שניות)"

msgid "How long browsers should remember to use HTTPS. 31536000 = 1 year (recommended)."
msgstr "כמה זמן דפדפנים ישמרו את ההעדפה ל-HTTPS. 31536000 = שנה (מומלץ)."

#: CSP section
msgid "Content Security Policy"
msgstr "מדיניות אבטחת תוכן"

msgid "Enable Content-Security-Policy header."
msgstr "הפעל כותרת Content-Security-Policy."

msgid "CSP Mode"
msgstr "מצב CSP"

msgid "Report-Only (log violations, don't block)"
msgstr "דיווח בלבד (רישום הפרות, ללא חסימה)"

msgid "Enforce (block violations)"
msgstr "אכיפה (חסימת הפרות)"

msgid "Start with Report-Only to test, then switch to Enforce once you've fixed all violations."
msgstr "התחל עם דיווח בלבד לבדיקה, ולאחר מכן עבור לאכיפה לאחר שתיקנת את כל ההפרות."

msgid "CSP Directives"
msgstr "הנחיות CSP"

msgid "Full CSP policy string. Example: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
msgstr "מחרוזת מדיניות CSP מלאה. דוגמה: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"

#: Hardening section
msgid "WordPress Hardening"
msgstr "חיזוק WordPress"

msgid "Hide REST API users endpoint from unauthenticated visitors"
msgstr "הסתר נקודת קצה של משתמשי REST API ממבקרים לא מאומתים"

msgid "Block author enumeration (?author=N and /author/ archives)"
msgstr "חסום ספירת מחברים (?author=N וארכיוני /author/)"

msgid "Remove WordPress version from page source"
msgstr "הסר גרסת WordPress מקוד המקור"

msgid "Remove RSD (Really Simple Discovery) link"
msgstr "הסר קישור RSD (Really Simple Discovery)"

msgid "Remove Windows Live Writer manifest link"
msgstr "הסר קישור Windows Live Writer"

msgid "Disable XML-RPC (legacy remote publishing protocol)"
msgstr "השבת XML-RPC (פרוטוקול פרסום מרחוק ישן)"

msgid "Enable [safe_email] shortcode for email obfuscation"
msgstr "הפעל קוד קצר [safe_email] להסתרת דוא״ל"

#: Standalone conflict
msgid "WP Starter Kit: Security Headers — the suite plugin is active, so this standalone version has been skipped. You can safely deactivate it."
msgstr "WP Starter Kit: Security Headers — תוסף הערכה פעיל, לכן הגרסה העצמאית דולגה. ניתן לבטל את הפעלתו בבטחה."
