#: Module identity
msgid "Brevo Mailer"
msgstr "דוא״ל Brevo"

msgid "Route all WordPress emails through Brevo (formerly Sendinblue) transactional API for reliable delivery."
msgstr "נתב את כל מיילי WordPress דרך ה-API של Brevo (לשעבר Sendinblue) לשליחה אמינה."

#: Settings fields
msgid "Brevo API Key"
msgstr "מפתח API של Brevo"

msgid "Your Brevo API key (v3). Find it in Brevo dashboard → SMTP & API → API Keys."
msgstr "מפתח ה-API של Brevo (v3). ניתן למצוא בלוח הבקרה של Brevo → SMTP & API → API Keys."

msgid "From Email"
msgstr "כתובת שולח"

msgid "Sender email address. Must be verified in your Brevo account."
msgstr "כתובת הדוא״ל של השולח. חייבת להיות מאומתת בחשבון Brevo שלך."

msgid "From Name"
msgstr "שם שולח"

msgid "Sender display name shown in recipients' inbox."
msgstr "שם השולח שיוצג בתיבת הדואר של הנמען."

msgid "Force From Address"
msgstr "אלץ כתובת שולח"

msgid "Always use the From Email above, even when other plugins set a different sender. Recommended for consistent deliverability."
msgstr "השתמש תמיד בכתובת השולח שלמעלה, גם כשתוספים אחרים מגדירים שולח אחר. מומלץ לשליחה עקבית."

msgid "Log Errors"
msgstr "רשום שגיאות"

msgid "Write failed email attempts to the WordPress error log (wp-content/debug.log)."
msgstr "רשום ניסיונות שליחה שנכשלו ליומן השגיאות של WordPress (wp-content/debug.log)."

#: Test email
msgid "Send Test Email"
msgstr "שלח מייל בדיקה"

msgid "Verify your configuration by sending a test email."
msgstr "אמת את ההגדרות שלך על ידי שליחת מייל בדיקה."

msgid "Recipient"
msgstr "נמען"

msgid "Send Test"
msgstr "שלח בדיקה"

msgid "Sending..."
msgstr "שולח..."

msgid "Permission denied."
msgstr "אין הרשאה."

msgid "Please enter a valid email address."
msgstr "אנא הזן כתובת דוא״ל תקינה."

#: Test email body
msgid "Test email from %s"
msgstr "מייל בדיקה מאתר %s"

msgid "This is a test email sent via WP Starter Kit: Brevo Mailer.\n\nTimestamp: %1$s\nSite: %2$s\n\nIf you received this, your Brevo mailer is working correctly."
msgstr "זהו מייל בדיקה שנשלח באמצעות WP Starter Kit: Brevo Mailer.\n\nזמן: %1$s\nאתר: %2$s\n\nאם קיבלת הודעה זו, הגדרת הדוא״ל עובדת כראוי."

msgid "Test email sent successfully to %s."
msgstr "מייל בדיקה נשלח בהצלחה אל %s."

msgid "Failed to send test email. Check the error log for details."
msgstr "שליחת מייל הבדיקה נכשלה. בדוק את יומן השגיאות לפרטים."

#: Admin notices
msgid "Brevo Mailer: API key is required for email delivery."
msgstr "Brevo Mailer: נדרש מפתח API לשליחת דוא״ל."

msgid "Configure now →"
msgstr "הגדר עכשיו →"

#: Standalone conflict notice
msgid "WP Starter Kit: Brevo Mailer — the suite plugin is active, so this standalone version has been skipped. You can safely deactivate it."
msgstr "WP Starter Kit: Brevo Mailer — תוסף הערכה פעיל, לכן הגרסה העצמאית דולגה. ניתן לבטל את הפעלתו בבטחה."
