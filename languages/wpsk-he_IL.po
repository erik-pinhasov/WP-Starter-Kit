msgid "WP Starter Kit"
msgstr "ערכת המפתחים של WP"

msgid "Enable or disable individual modules. Each module adds a specific feature to your WordPress site."
msgstr "הפעל או השבת מודולים בודדים. כל מודול מוסיף תכונה ספציפית לאתר ה-WordPress שלך."

msgid "Settings"
msgstr "הגדרות"

msgid "Save Changes"
msgstr "שמור שינויים"

msgid "WP Starter Kit: \"%s\" is already active via the suite plugin. The standalone version has been skipped."
msgstr "ערכת WP Starter Kit: \"%s\" כבר פעיל דרך תוסף הערכה. הגרסה העצמאית דולגה."
